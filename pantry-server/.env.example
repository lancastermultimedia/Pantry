# Recipe scraping — Spoonacular API
# Get a free key at https://spoonacular.com/food-api (150 req/day on free tier)
SPOONACULAR_API_KEY=your-spoonacular-api-key-here

# Server port (Railway sets this automatically; only needed locally)
PORT=3001

# Comma-separated list of allowed frontend origins for CORS.
# Add your Vercel deployment URL here (no trailing slash).
# Example: https://pantry.vercel.app
# Multiple: https://pantry.vercel.app,https://pantry-preview.vercel.app
CORS_ORIGIN=https://your-vercel-app.vercel.app
