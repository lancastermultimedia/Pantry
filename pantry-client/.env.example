# Supabase — Auth and database
# Find these in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend API URL — only needed in production.
# Set this to your deployed Railway/Render backend URL (no trailing slash).
# Leave blank locally — Vite's dev proxy handles it automatically.
# Example: https://pantry-server.up.railway.app
VITE_API_URL=
